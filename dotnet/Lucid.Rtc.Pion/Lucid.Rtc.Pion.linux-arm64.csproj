<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IncludeBuildOutput>false</IncludeBuildOutput>

    <!-- Package metadata -->
    <PackageId>Lucid.Rtc.Pion.linux-arm64</PackageId>
    <Description>Native runtime for Lucid.Rtc - Pion/Go backend (Linux ARM64)</Description>
    <PackageTags>webrtc;lucid;rtc;native;pion;go;linux-arm64</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Lucid.Rtc.Core\Lucid.Rtc.Core.csproj" />
  </ItemGroup>

  <ItemGroup Condition="Exists('linux-arm64\native\liblucid_rtc.so')">
    <None Include="linux-arm64\native\liblucid_rtc.so">
      <Pack>true</Pack>
      <PackagePath>runtimes\linux-arm64\native\</PackagePath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
