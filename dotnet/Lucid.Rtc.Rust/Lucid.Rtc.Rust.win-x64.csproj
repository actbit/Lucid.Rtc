<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IncludeBuildOutput>false</IncludeBuildOutput>

    <!-- Package metadata -->
    <PackageId>Lucid.Rtc.Rust.win-x64</PackageId>
    <Description>Native runtime for Lucid.Rtc - Rust backend (Windows x64)</Description>
    <PackageTags>webrtc;lucid;rtc;native;rust;win-x64</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Lucid.Rtc.Core\Lucid.Rtc.Core.csproj" />
  </ItemGroup>

  <!-- Include buildTransitive for NuGet framework detection -->
  <ItemGroup>
    <None Include="build\**" Pack="true" PackagePath="buildTransitive\" />
  </ItemGroup>

  <ItemGroup Condition="Exists('win-x64/native/lucid_rtc.dll')">
    <None Include="win-x64/native/lucid_rtc.dll">
      <Pack>true</Pack>
      <PackagePath>runtimes/win-x64/native/</PackagePath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
